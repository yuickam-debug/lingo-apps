    "grammarPoints": [
      {
        "rule": "Reflexive verb 'rejse sig' (to stand up / get up)",
        "exampleSentence": "Du rejser dig og danser lidt i stolen.",
        "explanation": "'Rejse sig' = 'to get up'. 'Sig' is the reflexive pronoun. Other reflexive movement verbs: 'sætte sig' (sit down), 'lægge sig' (lie down), 'vende sig' (turn around). These describe movement of the body relative to itself."
      },
      {
        "rule": "Indirect question with 'hvordan' keeps normal word order",
        "exampleSentence": "Spurgte du mig, hvordan Gud ser ud?",
        "explanation": "In Danish indirect questions, word order does NOT invert — subject comes before verb. 'Hvordan Gud ser ud' = subject 'Gud' + verb 'ser'. Compare: direct 'Hvordan ser Gud ud?' (inverted) vs indirect 'jeg spørger, hvordan Gud ser ud' (not inverted)."
      },
      {
        "rule": "Separable verb 'se ud' (to look like / to appear)",
        "exampleSentence": "Hvordan ser Gud ud?",
        "explanation": "'Se ud' splits: 'se' stays in verb position, 'ud' goes to the end. Meaning: 'to look like'. 'Hvordan ser han ud?' = 'What does he look like?'. 'Det ser godt ud' = 'That looks good'. One of the most frequent Danish phrasal verbs."
      }
    ],
