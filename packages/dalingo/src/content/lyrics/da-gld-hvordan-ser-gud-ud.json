{
  "id": "da-guldimund-hvordan-ser-gud-ud",
  "title": "Hvordan ser Gud ud?",
  "level": "B2",
  "genre": "lyrics",
  "source": "lyrics",
  "sentences": [
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s01",
      "text": "Med opmærksomheden rettet mod de nyspartlede huller i min stuevæg",
      "translation": "",
      "words": [
        {
          "word": "opmærksomheden",
          "definition": "attention",
          "partOfSpeech": ""
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s02",
      "text": "Irettesætter jeg dig med et tonefald, så hårdt, at det ku' bryde is",
      "translation": "",
      "words": [
        {
          "word": "irettesætter",
          "definition": "to reprimand / scold",
          "partOfSpeech": "verb (inf.)"
        },
        {
          "word": "tonefald",
          "definition": "a tone of voice",
          "partOfSpeech": "noun"
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s03",
      "text": "Fordi du spilder noget suppe, jeg har varmet op",
      "translation": "",
      "words": [
        {
          "word": "spilder",
          "definition": "to spill / waste",
          "partOfSpeech": "verb (inf.)"
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s04",
      "text": "Jeg sætter tommeltot og langefinger mellem mine øjne",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s05",
      "text": "Lukker dem i cirka ni sekunder, mens jeg ekshalerer dybt",
      "translation": "",
      "words": [
        {
          "word": "ekshalerer",
          "definition": "to exhale",
          "partOfSpeech": "verb (inf.)"
        },
        {
          "word": "cirka",
          "definition": "approximately / about",
          "partOfSpeech": ""
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s06",
      "text": "Lægger hovedet på skrå og ser på dig, før jeg roder rundt i dit grydehår og smiler lidt",
      "translation": "",
      "words": [
        {
          "word": "grydehår",
          "definition": "messy hair (lit. pot-hair, informal)",
          "partOfSpeech": ""
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s07",
      "text": "Du rejser dig og danser lidt i stolen",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s08",
      "text": "Jeg siger, du ska' sæt' dig ned",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s09",
      "text": "Du siger, jeg skal sige til mor",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s10",
      "text": "Du aldrig gider sove her igen",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s11",
      "text": "Så spurgte du mig, hvordan Gud ser ud?",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s12",
      "text": "Det er et virkelig godt spørgsmål, hva' tror du?",
      "translation": "",
      "words": [
        {
          "word": "spørgsmål",
          "definition": "a question",
          "partOfSpeech": "noun"
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s13",
      "text": "Du svared': »Jeg tror han bor i en landsby i Nordsjælland«",
      "translation": "",
      "words": [
        {
          "word": "landsby",
          "definition": "a village",
          "partOfSpeech": "noun"
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s14",
      "text": "Jeg parkerer dig i brusenichen med en spand af plastik",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s15",
      "text": "Og legetøj fra BR, som vi har valgt sammen",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s16",
      "text": "Og du synger: »na-na-na-na-na-na«",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s17",
      "text": "Jeg ka' høre dig, mens jeg rydder op",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s18",
      "text": "Og vi griner, da jeg gi'r dig din pyjamas på",
      "translation": "",
      "words": [
        {
          "word": "griner",
          "definition": "laughs / smiles (vi griner = we laugh)",
          "partOfSpeech": ""
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s19",
      "text": "Og jeg gnubber mildt, men energisk på din spinkle krop",
      "translation": "",
      "words": [
        {
          "word": "gnubber",
          "definition": "to rub / scrub",
          "partOfSpeech": "verb (inf.)"
        },
        {
          "word": "spinkle",
          "definition": "frail / slender / slight",
          "partOfSpeech": "verb (inf.)"
        }
      ]
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s20",
      "text": "Du rejser dig og danser lidt i sengen",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-hvordan-ser-gud-ud-s21",
      "text": "Jeg siger, at du skal læg' dig ned",
      "translation": "",
      "words": []
    },
    {
