    "grammarPoints": [
      {
        "rule": "Conditional perfect: 'ku' være blevet til' (could have become)",
        "exampleSentence": "Hva' ku' livet ikk' være blevet til?",
        "explanation": "'Ku'' = 'kunne', 'være blevet til' = past infinitive of 'blive til'. Together: 'could have become'. Full form: 'Hvad kunne livet ikke være blevet til?' = 'What could life not have become?' This expresses regret about paths not taken."
      },
      {
        "rule": "'Gå med nogen' — to date / be in a relationship",
        "exampleSentence": "Hvis det var hende, du var gået med?",
        "explanation": "'Gå med nogen' is a Danish idiom for being in a romantic relationship. 'Var gået med' = past perfect 'had gone out with'. 'Hvis det var hende, du var gået med' = 'If she had been the one you were with'."
      },
      {
        "rule": "'Stille op' — to do / manage / offer a solution",
        "exampleSentence": "Hva' ska' jeg stille op?",
        "explanation": "'Stille op' here means 'what can I do?' — expressing helplessness. Very common: 'jeg ved ikke hvad jeg skal stille op' = 'I don't know what to do'. Context changes its meaning (can also mean to set something up or to compete in an election)."
      }
    ],
