      "words": []
    },
    {
      "id": "da-guldimund-halskade-s04",
      "text": "Og det har skræmt dig",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-halskade-s05",
      "text": "Hun var sammen med sin nye kærest'",
