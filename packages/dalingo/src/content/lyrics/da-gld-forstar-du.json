  "sentences": [
    {
      "id": "da-guldimund-forstar-du-s01",
      "text": "»Hva' er det, der ikke er retfærdigt?« spørg' hun, mens hun læner sig ind over bordet",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-forstar-du-s02",
      "text": "»Du valgt' jo selv at gå«",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-forstar-du-s03",
      "text": "»Hva' er det, der ikke er retfærdigt?« gentager hun",
      "translation": "",
      "words": [
        {
          "word": "gentager",
          "definition": "to repeat (gentager = repeats)",
          "partOfSpeech": "verb (inf.)"
        }
      ]
    },
    {
      "id": "da-guldimund-forstar-du-s04",
      "text": "»Hør lig' her, jeg har rigtig mange sager, som er meget vær' end din«",
      "translation": "",
      "words": [
        {
          "word": "sager",
          "definition": "a case / matter",
          "partOfSpeech": "noun"
        }
      ]
    },
    {
      "id": "da-guldimund-forstar-du-s05",
      "text": "»Det hjælper jo selvfølgelig ikk' dig, men din ordning er fin«",
      "translation": "",
