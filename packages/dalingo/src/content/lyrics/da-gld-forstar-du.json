    "grammarPoints": [
      {
        "rule": "Impersonal 'man' (one / people in general)",
        "exampleSentence": "Man vil højst sandsynligt vurdere, at barnet har størst tilknytning til moren.",
        "explanation": "'Man' = 'one' or 'people in general' — avoids naming a specific person. Very common in formal, legal, and bureaucratic Danish. 'Man vurderer' = 'it is assessed / one assesses'. This song uses bureaucratic register deliberately to convey the coldness of the system."
      },
      {
        "rule": "'Sådan ligger landet' — that's how things are (idiom)",
        "exampleSentence": "Det' ikk' sådan landet ligger.",
        "explanation": "'Sådan ligger landet' literally means 'that's how the land lies' — an idiom for 'that's the situation / that's how it is'. Used to bluntly dismiss or explain a reality. Very common: 'Sådan er det bare, sådan ligger landet'."
      },
      {
        "rule": "Reported speech with 'hun si'r:' (direct quote with colon)",
        "exampleSentence": "Hun si'r: »Jeg beklager, men din tid er gået«",
        "explanation": "'Si'r' = 'siger' (says) — contracted. Danish introduces direct speech with a colon, then the words in » « quotes. This is the standard Danish dialogue format in writing. The » « marks are used where English would use double quotes."
      }
    ],
