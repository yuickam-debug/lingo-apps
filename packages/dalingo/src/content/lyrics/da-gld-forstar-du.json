      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-forstar-du-s11",
      "text": "I de her sager, hvor barnet er så lille",
      "translation": "",
      "words": [
        {
          "word": "sager",
          "definition": "a case / matter",
          "partOfSpeech": "noun"
        }
      ]
    },
    {
      "id": "da-guldimund-forstar-du-s12",
      "text": "Vil man højst sandsynligt vurdere, at barnet har størst tilknytning til moren",
      "translation": "",
      "words": [
        {
          "word": "tilknytning",
          "definition": "attachment / bond / connection",
          "partOfSpeech": ""
        },
        {
          "word": "vurdere",
