          "partOfSpeech": "verb (inf.)"
        }
      ]
    },
    {
      "id": "da-guldimund-forstar-du-s13",
      "text": "Det var hende, der gik på barsel, var det ikk'?",
      "translation": "",
      "words": [
        {
          "word": "barsel",
          "definition": "maternity / parental leave",
          "partOfSpeech": ""
        }
      ]
    },
    {
      "id": "da-guldimund-forstar-du-s14",
      "text": "Jeg hører højlydte stemmer bag en skydevæg",
      "translation": "",
      "words": [
        {
          "word": "skydevæg",
          "definition": "a sliding partition wall",
          "partOfSpeech": "noun"
        }
      ]
    },
    {
      "id": "da-guldimund-forstar-du-s15",
      "text": "Hva' ærgrer du dig for, det' ikk' sådan landet ligger",
      "translation": "",
      "words": []
    },
    {
      "id": "da-guldimund-forstar-du-s16",
      "text": "Og den ret til delt bopæl, du har læst om, eksisterer bare ikke",
      "translation": "",
      "words": []
    },
    {
