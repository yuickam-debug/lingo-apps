    "grammarPoints": [
      {
        "rule": "'Vil du noget (med mig)?' — romantic idiom",
        "exampleSentence": "Vil du noget? Vil du noget med mig?",
        "explanation": "Literally 'Do you want something?' but 'Vil du noget med mig?' is a Danish idiom meaning 'Are you interested in me?' — colloquial way to express romantic intent. The ambiguity is intentional: it can mean anything from 'do you want to hang out' to 'do you like me'."
      },
      {
        "rule": "'Ku'' = 'kunne' and other B2 contractions",
        "exampleSentence": "Jeg ku' smadre noget.",
        "explanation": "'Ku'' = 'kunne' (could), 'ta'' = 'tage'. At B2+ level, recognising these contractions is essential for listening comprehension in Danish — they appear constantly in songs, podcasts, and casual speech."
      },
      {
        "rule": "'Drukne i' — to be overwhelmed by (metaphor)",
        "exampleSentence": "Drukner i afmagt og kedsomhed og smerte.",
        "explanation": "'Drukne' means 'to drown'. 'Drukne i noget' is a very common Danish metaphor: 'drukner i afmagt' = 'drowning in helplessness', 'drukner i arbejde' = 'drowning in work'. Use it whenever someone is completely overwhelmed."
      }
